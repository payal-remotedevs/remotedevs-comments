{
  "name": "remotedevs/rd-comments",
  "type": "typo3-cms-extension",
  "description": "Comment extension for TYPO3",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Abhay Rathod",
      "role": "Developer"
    },
    {
      "name": "Karan Anjara",
      "role": "Maintainer"
    }
  ],
  "support": {
    "issues": "https://github.com/payal-remotedevs/remotedevs-comments/issues"
  },
  "require": {
    "typo3/cms-core": "^12.0",
    "georgringer/news": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "RemoteDevs\\RdComments\\": "Classes/"
    }
  },
  "replace": {
    "typo3-ter/rd_comments": "self.version"
  },
  "config": {
    "vendor-dir": ".Build/vendor",
    "bin-dir": ".Build/bin"
  },
  "extra": {
    "typo3/cms": {
      "cms-package-dir": "{$vendor-dir}/typo3/cms",
      "web-dir": ".Build/public",
      "extension-key": "rd_comments"
    }
  }
}
